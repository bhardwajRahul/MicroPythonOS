# Display settings:
SPI_BUS = const(1)  # SPI2
SPI_FREQ = const(40000000)

LCD_SCLK = const(18)
LCD_MOSI = const(23)
LCD_DC = const(27)
LCD_CS = const(14)
LCD_BL = const(32)
LCD_RST = const(33)
LCD_TYPE = const(2)  # ILI9341 type 2

TFT_HOR_RES = const(320)
TFT_VER_RES = const(240)

# Button settings:
BUTTON_A = const(39)  # A
BUTTON_B = const(38)  # B
BUTTON_C = const(37)  # C

# Misc settings:
