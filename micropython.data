        def active(self, is_active=None):
            if is_active is None:
                return self._active
            self._active = is_active
            return None

        def isconnected(self):
            return self._connected

        def connect(self, ssid, password):
            self._connected = True
            self._config["essid"] = ssid

        def disconnect(self):
            self._connected = False

        def config(self, *args, **kwargs):
            if kwargs:
                self._config.update(kwargs)
                return None
            if args:
                return self._config.get(args[0])
            return self._config

        def ifconfig(self, cfg=None):
            if cfg is None:
                return self._ifconfig
            self._ifconfig = cfg
            return None

        def ipconfig(self, key=None):
            config = self.ifconfig()
            mapping = {
                "addr4": config[0],
                "netmask4": config[1],
                "gw4": config[2],
                "dns4": config[3],
            }
            if key is None:
                return mapping
            return mapping.get(key)

        def scan(self):
            return self._scan_results

    def __init__(self):
        self._wlan_instances = {}

    def WLAN(self, interface):
        if interface not in self._wlan_instances:
            self._wlan_instances[interface] = self.MockWLAN(interface)
        return self._wlan_instances[interface]


class MockADC:
