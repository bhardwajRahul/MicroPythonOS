                     _AXP2101_ALDO3_VOL_STEPS)
        super().writeRegister(_AXP2101_LDO_VOL2_CTRL, val)

    def getALDO3Voltage(self) -> int:
        val = super().readRegister(_AXP2101_LDO_VOL2_CTRL)[0] & 0x1F
