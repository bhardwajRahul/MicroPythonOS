from mpos.imu.constants import (
    TYPE_ACCELEROMETER,
    TYPE_MAGNETIC_FIELD,
    TYPE_GYROSCOPE,
    TYPE_TEMPERATURE,
    TYPE_IMU_TEMPERATURE,
